{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "filesystem-access",
  "description": "File system access capability for EvorBrain",
  "windows": ["main"],
  "permissions": [
    {
      "identifier": "fs:allow-read-dir",
      "allow": [
        {
          "path": "$HOME/**"
        },
        {
          "path": "$APPDATA/**"
        },
        {
          "path": "$LOCALAPPDATA/**"
        }
      ]
    },
    {
      "identifier": "fs:allow-read-file",
      "allow": [
        {
          "path": "$HOME/**"
        },
        {
          "path": "$APPDATA/**"
        },
        {
          "path": "$LOCALAPPDATA/**"
        }
      ]
    },
    {
      "identifier": "fs:allow-write-file",
      "allow": [
        {
          "path": "$HOME/.evorbrain/**"
        },
        {
          "path": "$APPDATA/evorbrain/**"
        },
        {
          "path": "$LOCALAPPDATA/evorbrain/**"
        }
      ]
    },
    {
      "identifier": "fs:allow-create",
      "allow": [
        {
          "path": "$HOME/.evorbrain/**"
        },
        {
          "path": "$APPDATA/evorbrain/**"
        },
        {
          "path": "$LOCALAPPDATA/evorbrain/**"
        }
      ]
    },
    {
      "identifier": "fs:allow-remove",
      "allow": [
        {
          "path": "$HOME/.evorbrain/**"
        },
        {
          "path": "$APPDATA/evorbrain/**"
        },
        {
          "path": "$LOCALAPPDATA/evorbrain/**"
        }
      ]
    },
    {
      "identifier": "fs:allow-rename",
      "allow": [
        {
          "path": "$HOME/.evorbrain/**"
        },
        {
          "path": "$APPDATA/evorbrain/**"
        },
        {
          "path": "$LOCALAPPDATA/evorbrain/**"
        }
      ]
    },
    {
      "identifier": "fs:allow-exists",
      "allow": [
        {
          "path": "$HOME/**"
        },
        {
          "path": "$APPDATA/**"
        },
        {
          "path": "$LOCALAPPDATA/**"
        }
      ]
    },
    {
      "identifier": "fs:allow-mkdir",
      "allow": [
        {
          "path": "$HOME/.evorbrain/**"
        },
        {
          "path": "$APPDATA/evorbrain/**"
        },
        {
          "path": "$LOCALAPPDATA/evorbrain/**"
        }
      ]
    },
    {
      "identifier": "fs:allow-copy-file",
      "allow": [
        {
          "path": "$HOME/.evorbrain/**"
        },
        {
          "path": "$APPDATA/evorbrain/**"
        },
        {
          "path": "$LOCALAPPDATA/evorbrain/**"
        }
      ]
    }
  ],
  "platforms": ["linux", "macOS", "windows"]
}