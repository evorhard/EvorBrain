{
  "name": "evorbrain",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "EvorBrain - Offline-first personal productivity system",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "tauri:build:debug": "tauri build --debug",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "lint": "eslint src --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint src --ext ts,tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,js,jsx,json,css}\"",
    "type-check": "tsc --noEmit",
    "check-all": "npm run type-check && npm run lint && npm run format:check"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/evorhard/evorbrain.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/evorhard/evorbrain/issues"
  },
  "homepage": "https://github.com/evorhard/evorbrain#readme",
  "devDependencies": {
    "@tauri-apps/cli": "^2.6.2",
    "@types/node": "^22.5.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@testing-library/jest-dom": "^6.4.6",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@typescript-eslint/eslint-plugin": "^7.16.0",
    "@typescript-eslint/parser": "^7.16.0",
    "@vitejs/plugin-react": "^4.6.0",
    "eslint": "^8.57.0",
    "eslint-plugin-react": "^7.34.3",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.7",
    "jsdom": "^24.1.1",
    "prettier": "^3.3.3",
    "typescript": "^5.8.3",
    "vite": "^7.0.4",
    "vitest": "^2.0.4"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.6.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  }
}
